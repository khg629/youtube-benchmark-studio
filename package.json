{
  "name": "youtube-benchmark",
  "version": "0.1.2",
  "description": "Personal YouTube benchmarking and LLM analysis studio",
  "author": "YouTube Benchmark Studio",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "desktop:dev": "electron electron/main.cjs",
    "rebuild:native": "npm rebuild better-sqlite3",
    "prepare:desktop-runtime": "node scripts/prepare-desktop-runtime.cjs",
    "dist:dir": "npm run rebuild:native && npm run build && npm run prepare:desktop-runtime && electron-builder --dir --publish never",
    "dist": "npm run rebuild:native && npm run build && npm run prepare:desktop-runtime && electron-builder --publish never",
    "dist:mac": "npm run rebuild:native && npm run build && npm run prepare:desktop-runtime && electron-builder --mac --publish never",
    "dist:win": "npm run rebuild:native && npm run build && npm run prepare:desktop-runtime && electron-builder --win --publish never"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.68.0",
    "@google/generative-ai": "^0.24.1",
    "better-sqlite3": "^12.10.0",
    "next": "15.5.0",
    "openai": "^4.77.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "youtubei.js": "^17.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "electron": "^34.5.8",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.3"
  },
  "build": {
    "appId": "studio.youtube-benchmark.desktop",
    "productName": "YouTube Benchmark Studio",
    "asar": false,
    "directories": {
      "output": "release"
    },
    "npmRebuild": false,
    "extraResources": [
      {
        "from": "desktop-runtime",
        "to": "desktop-runtime"
      }
    ],
    "files": [
      "app/**/*",
      "components/**/*",
      "electron/**/*",
      "lib/**/*",
      "scripts/**/*",
      ".next/**/*",
      "next.config.mjs",
      "next-env.d.ts",
      "package.json",
      "postcss.config.mjs",
      "tsconfig.json",
      "node_modules/**/*",
      "!data/**/*",
      "!release/**/*",
      "!desktop-runtime/**/*",
      "!.dev-server.log",
      "!tsconfig.tsbuildinfo"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*",
      "node_modules/@img/**/*",
      "node_modules/sharp/**/*"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
